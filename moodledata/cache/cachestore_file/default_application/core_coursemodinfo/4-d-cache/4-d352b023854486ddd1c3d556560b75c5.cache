O:26:"core_cache\version_wrapper":2:{s:4:"data";O:8:"stdClass":9:{s:7:"modinfo";a:14:{i:3;O:8:"stdClass":17:{s:2:"id";s:1:"2";s:2:"cm";s:1:"3";s:3:"mod";s:5:"label";s:7:"section";s:1:"0";s:13:"sectionnumber";s:1:"0";s:9:"sectionid";s:1:"3";s:6:"module";s:2:"13";s:5:"added";s:10:"1689189394";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"showdescription";s:1:"1";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:53:"Dear student,We hope you are well.We would like to...";s:7:"content";s:6028:"<div class="no-overflow"><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">Dear student,</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">We hope&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou are well.</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">We would like to introduce&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou to the objectives of this self-study e-learning course that we have created for&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou:</span></p><ol start="1" type="1"><li data-ogsc="rgb(0, 32, 96)"><span lang="EN-GB" data-ogsc="">To offer&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="" data-ogsb="">y</span>ou an additional original proposal to accompany&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="" data-ogsb="">y</span>our exchange experience. The purpose of the course is to help&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="" data-ogsb="">y</span>ou validate and become aware of the softskills-related learning that&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="" data-ogsb="">y</span>ou will certainly develop during&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="" data-ogsb="">y</span>our experience in an international context.</span></li></ol><ol start="2" type="1"><li data-ogsc="rgb(0, 32, 96)"><span lang="EN-GB" data-ogsc="">Give&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="" data-ogsb="">y</span>ou the opportunity to deepen:</span></li></ol><span style="font-size: 1rem;"><ul><li><span style="font-size: 1rem;">on the development of competences linked to curiosity and openness to diversity in a multicultural context.</span><br></li></ul></span><ul><li><span style="font-size: 1rem;">on the need for a global engagement (human rights, environment, equity and inclusion, etc.) and on the skills that come into play in the contrast with the exchange experience and the return to everyday life.</span></li><li><span style="font-size: 1rem;">on the development of skills linked to adaptability and openness to new learning offered by contact with people from different backgrounds. As well as the need to carry out day-to-day tasks, both at and outside the university, and in general in living independently in this context.</span></li><li><span style="font-size: 1rem;">on the opportunity to develop the problem-solving and decision-making skills throughout the exchange process (before, during and after), addressing issues such as digitisation and linguistic competence.</span><br></li></ul><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">This proposal is <strong>open and voluntary </strong>and of course,&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou are welcome to develop it as&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou wish:</span></p><p></p><ul><li><span style="font-size: 1rem;">Individually or together with other students who are participating in an exchange experience.</span><br></li><li><span style="font-size: 1rem;">In the format that suits&nbsp;</span><span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)" style="font-size: 1rem;">y</span><span style="font-size: 1rem;">ou best (notebook, corkboard, A2, podcast, mini-videos...).</span><br></li></ul><p></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">Customise&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>our learning pathway, map&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>our experience, adapting it to&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>our personal characteristics and focusing on the development of a professional profile enriched by the exchange experience, beyond the academic aspects.</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">We encourage&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou to share the final result of&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>our mapping experience with the rest of the participants.&nbsp;</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">If&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou feel like it,&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou can also share&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>our mapping with the ORI. We are very interested in knowing the details of&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>our exchange experience in order to better guide other exchange students in the future.</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">Thank&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>ou very much in advance for&nbsp;<span data-markjs="true" data-ogac="" data-ogab="" data-ogsc="black" data-ogsb="rgb(255, 241, 0)">y</span>our participation.</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">Have a nice day, take care.</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">&nbsp;</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">Kind regards,</span><span style="font-size: 1rem;">&nbsp;</span></p><p><span lang="EN-GB" data-ogsc="rgb(0, 32, 96)">IRO Team</span></p></div>";}i:4;O:8:"stdClass":17:{s:2:"id";s:1:"3";s:2:"cm";s:1:"4";s:3:"mod";s:5:"label";s:7:"section";s:1:"0";s:13:"sectionnumber";s:1:"0";s:9:"sectionid";s:1:"3";s:6:"module";s:2:"13";s:5:"added";s:10:"1686820497";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"showdescription";s:1:"1";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:53:"Contact other students who will be or have been on...";s:7:"content";s:168:"<div class="no-overflow"><h5 dir="ltr" style="text-align: left;">Contact other students who will be or have been on exchange in your destination country.<br></h5></div>";}i:5;O:8:"stdClass":17:{s:2:"id";s:1:"2";s:2:"cm";s:1:"5";s:3:"mod";s:5:"forum";s:7:"section";s:1:"0";s:13:"sectionnumber";s:1:"0";s:9:"sectionid";s:1:"3";s:6:"module";s:1:"9";s:5:"added";s:10:"1686898229";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:9:"groupmode";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:49:"Forum for students sharing country of destination";s:10:"customdata";a:1:{s:12:"trackingtype";s:1:"1";}}i:6;O:8:"stdClass":17:{s:2:"id";s:1:"4";s:2:"cm";s:1:"6";s:3:"mod";s:5:"label";s:7:"section";s:1:"0";s:13:"sectionnumber";s:1:"0";s:9:"sectionid";s:1:"3";s:6:"module";s:2:"13";s:5:"added";s:10:"1686819963";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"showdescription";s:1:"1";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:28:"Map your exchange experience";s:7:"content";s:125:"<div class="no-overflow"><h5 dir="ltr" style="text-align: left;"><strong>Map your exchange experience</strong><br></h5></div>";}i:7;O:8:"stdClass":15:{s:2:"id";s:1:"1";s:2:"cm";s:1:"7";s:3:"mod";s:6:"folder";s:7:"section";s:1:"0";s:13:"sectionnumber";s:1:"0";s:9:"sectionid";s:1:"3";s:6:"module";s:1:"8";s:5:"added";s:10:"1686820359";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:53:"Resources to explore and map your exchange experience";}i:8;O:8:"stdClass":17:{s:2:"id";s:1:"5";s:2:"cm";s:1:"8";s:3:"mod";s:5:"label";s:7:"section";s:1:"1";s:13:"sectionnumber";s:1:"1";s:9:"sectionid";s:1:"4";s:6:"module";s:2:"13";s:5:"added";s:10:"1689190354";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"showdescription";s:1:"1";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:53:"We start with the first block, please don't miss t...";s:7:"content";s:5917:"<div class="no-overflow"><p dir="ltr" style="text-align: left;"></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">We start with the first block, please don't miss the mini-video&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🔥</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;and participate virtually in a conversation&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">☕</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;about the initial paperwork&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">😓</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">, the most common difficulties of adaptation to the new context&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">💌</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">👩💻</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;and&nbsp;</span><em><span data-ogsc="red" lang="EN-GB">erasmusapp.eu</span></em><span data-ogsc="red" lang="EN-GB">&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🤳</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;as a common space of orientation for the exchange period.</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">The conversation helps us to explain how we will accompany&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🤹&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">️ your exchange from the IRO. At the end of this section you will find a list of&nbsp;<em>FAQs&nbsp;</em>that students usually ask us 'before the exchange'.</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">We feel connected to you because we have also lived an exchange experience&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">👵</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">. There is so much we learned in that time&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">👷</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">️</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">😊</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;today we know how helpful it is to name those new skills and strategies that later served us in our personal and professional development. This course aims to help you broaden your vision&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🕵</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">️</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">️, to help you explore learning that goes beyond academic content.</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">You will remember this from our first briefing&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🏁</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;Don't you remember? No problem, you can always access the content of the first briefing (pdf)&nbsp;</span><a href="https://web.unican.es/unidades/oficina-relaciones-internacionales/Documents/OUTGOING_23-24_Primera_Reunion_marzo_23.pdf" target="_blank"><em>from here.</em></a></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">In this period (before the mobility) you start to develop new skills&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">😎</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">. We deal with paperwork but at the same time we bring into play our skills in a context of digitalisation&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">👨💻</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;and our skills to manage in a multicultural context&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🌍</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">.</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">We have created a pathway to help you become aware of these new skills, but first access the mini-video&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🔥</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;it's important!</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">If you have already watched the mini video&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🔥</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;the next step is to access the different key questions on cultural diversity.</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">Finally, get to know our proposal for the development of the personal exploration process&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🕵</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">️</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">️ that will help you later on to defend the added value of a professional profile of someone who has participated in an exchange experience, complex, yes, but we assure you that when you have lived it everything makes sense.</span></p><br><p></p><p dir="ltr" style="text-align: left;"></p>
<p></p>
<p>Block presentation (voice memo, Spanish):&nbsp;<a href="https://personales.gestion.unican.es/ruizlj/b01.mp3">Presentación Bloque 01</a><br></p>
<p><span style="color: rgb(73, 80, 87); font-size: 0.9375rem;">&nbsp;🏁 </span><a href="https://web.unican.es/unidades/oficina-relaciones-internacionales/Documents/OUTGOING_23-24_Primera_Reunion_marzo_23.pdf" target="_blank" style="background-color: rgb(255, 255, 255); font-size: 0.9375rem;">Content of the first information meeting, Spanish (pdf)</a></p>
<p><span style="font-size: 0.9375rem; color: rgb(73, 80, 87);">🕵️‍♂️ <a href="http://localhost/moodle/mod/folder/view.php?id=7">Proposal for the development of the personal exploration process (mapping your exchange experience)</a></span></p>
<div><span style="font-size: 0.9375rem;">🌍 <a href="https://Erasmusapp.eu" target="_blank">Erasmusapp.eu</a></span><br></div>
<p></p></div>";}i:9;O:8:"stdClass":19:{s:2:"id";s:1:"1";s:2:"cm";s:1:"9";s:3:"mod";s:8:"resource";s:7:"section";s:1:"1";s:13:"sectionnumber";s:1:"1";s:9:"sectionid";s:1:"4";s:6:"module";s:2:"18";s:5:"added";s:10:"1686225181";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:10:"completion";s:1:"2";s:19:"completionpassgrade";s:1:"0";s:14:"completionview";s:1:"1";s:15:"downloadcontent";s:1:"1";s:4:"lang";N;s:4:"icon";s:5:"f/pdf";s:4:"name";s:52:"🤔 Frequently asked questions: BEFORE the exchange";s:10:"customdata";a:3:{s:10:"filtericon";b:1;s:14:"displayoptions";s:224:"a:4:{s:10:"printintro";i:1;s:8:"showtype";i:1;s:8:"showdate";i:1;s:11:"filedetails";a:4:{s:4:"type";s:12:"PDF document";s:8:"mimetype";s:15:"application/pdf";s:9:"extension";s:3:"PDF";s:12:"uploadeddate";s:10:"1773250862";}}";s:7:"display";s:1:"1";}}i:10;O:8:"stdClass":17:{s:2:"id";s:1:"6";s:2:"cm";s:2:"10";s:3:"mod";s:5:"label";s:7:"section";s:1:"2";s:13:"sectionnumber";s:1:"2";s:9:"sectionid";s:1:"5";s:6:"module";s:2:"13";s:5:"added";s:10:"1689226967";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"showdescription";s:1:"1";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:53:"We continue with the second block, please do not m...";s:7:"content";s:3167:"<div class="no-overflow"><p><span style="font-size: 1rem;" class=""></span></p>
<p></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">We continue with the second block, please do not miss the mini-video&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🔥</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;and participate virtually in a conversation&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">☕</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;about learning from the first day&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">😓</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">, getting by in the first classes, the trip and managing in a second language...</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">The conversation helps us to explain how we will accompany&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🤹</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;your exchange from the IRO, at the end of this section you will find the most frequently asked questions about the language training prior to the exchange and the OLS.</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">In this period (at the beginning of your exchange) you start to develop new skills&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">😎</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">. We learn from day one by putting our skills into play in a context of cultural diversity and which requires losing the fear of expressing ourselves in another language.</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">We have created an itinerary to help you become aware of these new skills, but first access the mini-video&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🔥</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;it's important!</span></p><p><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">If you have already watched the mini-video&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">🔥</span><span data-ogsc="rgb(31, 73, 125)" lang="EN-GB">&nbsp;the next step is to access the content that helps us think about cultural diversity and the global studies approach through different audio-visual resources.</span></p><p><span data-ogsc="rgb(31, 73, 125)" style="font-size: 1rem;" lang="EN-GB">Finally, remember our proposal for the development of the personal exploration process&nbsp;</span><span data-ogsc="rgb(31, 73, 125)" style="font-size: 1rem;" lang="EN-GB">🕵</span><span data-ogsc="rgb(31, 73, 125)" style="font-size: 1rem;" lang="EN-GB">️</span><span data-ogsc="rgb(31, 73, 125)" style="font-size: 1rem;" lang="EN-GB">️ that will help you later on to defend the added value of a professional profile of someone who has participated in an exchange experience. Complex? Yes, but we assure you that when you have lived it everything makes sense.</span></p><br><p></p>
<p>Block presentation (voice memo, Spanish):&nbsp;<a href="https://personales.gestion.unican.es/ruizlj/B02.mp3" style="background-color: rgb(255, 255, 255); font-size: 0.9375rem;">Presentación Bloque 2</a></p></div>";}i:11;O:8:"stdClass":15:{s:2:"id";s:1:"1";s:2:"cm";s:2:"11";s:3:"mod";s:4:"page";s:7:"section";s:1:"2";s:13:"sectionnumber";s:1:"2";s:9:"sectionid";s:1:"5";s:6:"module";s:2:"16";s:5:"added";s:10:"1688982423";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:53:"🎬 Chimamanda Adichie: The danger of a single story";}i:12;O:8:"stdClass":17:{s:2:"id";s:1:"2";s:2:"cm";s:2:"12";s:3:"mod";s:8:"resource";s:7:"section";s:1:"2";s:13:"sectionnumber";s:1:"2";s:9:"sectionid";s:1:"5";s:6:"module";s:2:"18";s:5:"added";s:10:"1688982854";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"icon";s:5:"f/pdf";s:4:"name";s:57:"🤔 Frequently Asked Questions on Language Training, OLS";s:10:"customdata";a:3:{s:10:"filtericon";b:1;s:14:"displayoptions";s:28:"a:1:{s:10:"printintro";i:1;}";s:7:"display";i:5;}}i:13;O:8:"stdClass":17:{s:2:"id";s:1:"7";s:2:"cm";s:2:"13";s:3:"mod";s:5:"label";s:7:"section";s:1:"3";s:13:"sectionnumber";s:1:"3";s:9:"sectionid";s:1:"6";s:6:"module";s:2:"13";s:5:"added";s:10:"1689195654";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"showdescription";s:1:"1";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:53:"We continue with the second block, please do not m...";s:7:"content";s:3149:"<div class="no-overflow"><p><span style="font-size: 0.9375rem;"></span></p><p><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">We continue with the second block, please do not miss the mini-video&nbsp;</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">🔥</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">&nbsp;and participate virtually in a conversation&nbsp;</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">☕</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">&nbsp;about learning from the first day&nbsp;</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">😓</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">, getting by in the first classes, the trip and managing in a second language...</span></p><p><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">The conversation helps us to explain how we will accompany&nbsp;</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">🤹</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">️ your exchange from the IRO, at the end of this section you will find the most frequently asked questions about the language training prior to the exchange and the OLS.</span></p><p><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">In this period (at the beginning of your exchange) you start to develop new skills&nbsp;</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">😎</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">. We learn from day one by putting our skills into play in a context of cultural diversity and which requires losing the fear of expressing ourselves in another language.</span></p><p><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">We have created an itinerary to help you become aware of these new skills, but first access the mini-video&nbsp;</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">🔥</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">&nbsp;it's important!</span></p><p><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">If you have already watched the mini-video&nbsp;</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">🔥</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">&nbsp;the next step is to access the content that helps us think about cultural diversity and the global studies approach through different audio-visual resources.</span><span style="font-size: 1rem;">&nbsp;</span></p><p><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">Finally, remember our proposal for the development of the personal exploration process&nbsp;</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">🕵</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">️</span><span lang="EN-GB" data-ogsc="rgb(31, 73, 125)">️ that will help you later on to defend the added value of a professional profile of someone who has participated in an exchange experience. Complex? Yes, but we assure you that when you have lived it everything makes sense.</span></p><br>Presentación del bloque (nota de voz, Spanish):&nbsp;<a href="https://personales.gestion.unican.es/ruizlj/B03.mp3" style="font-size: 0.9375rem; background-color: rgb(255, 255, 255);">Presentación Bloque 03</a><br><p></p>
<div style="color:#d20c0c;">
    <p></p>
</div></div>";}i:14;O:8:"stdClass":17:{s:2:"id";s:1:"8";s:2:"cm";s:2:"14";s:3:"mod";s:5:"label";s:7:"section";s:1:"4";s:13:"sectionnumber";s:1:"4";s:9:"sectionid";s:1:"7";s:6:"module";s:2:"13";s:5:"added";s:10:"1688471796";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"showdescription";s:1:"1";s:15:"downloadcontent";s:1:"1";s:4:"lang";N;s:4:"name";s:53:"In this section you will find the resources we hav...";s:7:"content";s:428:"<div class="no-overflow"><p dir="ltr" style="text-align: left;"></p><p dir="ltr" style="text-align: right;"><img src="http://localhost/moodle/pluginfile.php/67/mod_label/intro/Logo%20Peee-IR-View.png" alt="Peer-IR-View Logo" width="299" height="57"></p><p dir="ltr"><span class="" style="color: rgb(0, 46, 184);">In this section you will find the resources we have used to develop this Moodle course.</span></p><br><p></p></div>";}i:15;O:8:"stdClass":15:{s:2:"id";s:1:"2";s:2:"cm";s:2:"15";s:3:"mod";s:6:"folder";s:7:"section";s:1:"4";s:13:"sectionnumber";s:1:"4";s:9:"sectionid";s:1:"7";s:6:"module";s:1:"8";s:5:"added";s:10:"1688471752";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:9:"Resources";}i:16;O:8:"stdClass":17:{s:2:"id";s:1:"1";s:2:"cm";s:2:"16";s:3:"mod";s:8:"feedback";s:7:"section";s:1:"4";s:13:"sectionnumber";s:1:"4";s:9:"sectionid";s:1:"7";s:6:"module";s:1:"7";s:5:"added";s:10:"1689239586";s:7:"visible";s:1:"1";s:19:"visibleoncoursepage";i:1;s:10:"visibleold";s:1:"1";s:9:"groupmode";s:1:"1";s:19:"completionpassgrade";s:1:"0";s:15:"downloadcontent";s:1:"1";s:4:"lang";s:0:"";s:4:"name";s:50:"Please share your feedback (Peer-IR-View partners)";s:10:"customdata";a:1:{s:9:"anonymous";s:1:"1";}}}s:12:"sectioncache";a:5:{i:3;O:8:"stdClass":7:{s:2:"id";s:1:"3";s:7:"section";s:1:"0";s:4:"name";s:19:"Propuesta del curso";s:7:"summary";s:54:"<p di